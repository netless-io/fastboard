{
  "name": "@netless/fastboard-core",
  "version": "1.1.5",
  "description": "A tiny wrapper of white-web-sdk and @netless/window-manager and @netless/appliance-plugin.",
  "main": "src/index.ts",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "repository": "netless-io/fastboard",
  "scripts": {
    "cleanup": "rimraf dist",
    "check": "tsc --noEmit",
    "build": "buildtool"
  },
  "dependencies": {
    "@netless/app-slide": "^0.2.99",
    "@netless/synced-store": "^2.0.7"
  },
  "peerDependencies": {
    "@netless/app-in-mainview-plugin": ">=0.0.9",
    "@netless/appliance-plugin": ">=1.1.35",
    "@netless/window-manager": ">=1.0.14",
    "jspdf": ">=2.5.1",
    "white-web-sdk": ">=2.16.54"
  },
  "devDependencies": {
    "@netless/buildtool": "workspace:*",
    "jspdf": "^2.5.1",
    "white-web-sdk": "^2.16.54",
    "@netless/window-manager": "^1.0.14"
  },
  "optionalDependencies": {
    "@netless/app-in-mainview-plugin": "^0.0.9",
    "@netless/appliance-plugin": "^1.1.35"
  },
  "publishConfig": {
    "access": "public",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      }
    }
  }
}
