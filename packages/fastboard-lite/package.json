{
  "name": "@netless/fastboard-lite",
  "version": "1.1.5-beta.4",
  "description": "Lite version of @netless/fastboard.",
  "source": "../fastboard/src/index.ts",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "repository": "netless-io/fastboard",
  "scripts": {
    "cleanup": "rimraf dist",
    "build": "buildtool",
    "dev": "vite"
  },
  "dependencies": {
    "@netless/fastboard-core-lite": "workspace:*",
    "@netless/fastboard-ui": "workspace:*"
  },
  "devDependencies": {
    "@netless/buildtool": "workspace:*"
  },
  "publishConfig": {
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      }
    }
  }
}
